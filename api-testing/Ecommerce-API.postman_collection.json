          "name": "Remove from Wishlist",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{product_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/wishlist/remove",
              "host": ["{{base_url}}"],
              "path": ["api", "wishlist", "remove"]
            },
            "description": "Remove a product from wishlist."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Orders",
      "description": "Order creation and management (requires auth).",
      "item": [
        {
          "name": "Create Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "  const body = pm.response.json();",
                  "  if (body._id) {",
                  "    pm.collectionVariables.set('order_id', body._id);",
                  "  }",
                  "} catch(e) {}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cartId\": \"{{cart_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/order/create-order",
              "host": ["{{base_url}}"],
              "path": ["api", "order", "create-order"]
            },
            "description": "Create order from cart. Removes expiration job, sends confirmation email.\nTest script auto-saves order_id."
          },
          "response": []
        },
        {
          "name": "Request Refund / Cancel",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/orders?orderId={{order_id}}&action=cancel",
              "host": ["{{base_url}}"],
              "path": ["api", "orders"],
              "query": [
                { "key": "orderId", "value": "{{order_id}}", "description": "Order ID" },
                { "key": "action", "value": "cancel", "description": "refund or cancel" }
              ]
            },
            "description": "Request refund (order must be delivered) or cancel (order must not be shipped/delivered)."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Admin - Orders",
      "description": "Admin order management (requires admin auth).",
      "item": [
        {
          "name": "Update Order Status",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{order_id}}\",\n  \"status\": \"processing\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/orders/status",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "orders", "status"]
            },
            "description": "Update order status: processing → shipped → delivered → cancelled/refunded"
          },
          "response": []
        },
        {
          "name": "Get Order By ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/admin/orders/{{order_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "orders", "{{order_id}}"]
            },
            "description": "Get a specific order by ID."
          },
          "response": []
        },
        {
          "name": "Get Orders by Status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/admin/orders?action=delivered",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "orders"],
              "query": [
                { "key": "action", "value": "delivered", "description": "refundRequested, cancelRequested, delivered, shipped, processing, cancelled, refunded" }
              ]
            },
            "description": "Filter orders by status. Leave empty for all (latest 10)."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Admin - Sales Analytics",
      "description": "Sales reporting (requires admin auth).",
      "item": [
        {
